{
  "name": "lamp",
  "private": true,
  "version": "1.0.0",
  "main": "main.cjs",
  "type": "module",
  "description": "A notebook base on Electron & Vue.",
  "author": "Shaloong",
  "scripts": {
    "dev": "vite",
    "dev:ui": "vite --port 1086",
    "dev:desktop": "npm-run-all --parallel dev:ui auto-start",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "auto-start": "nodemon --exec electron . --watch ./ --ext .js,.html,.css,.vue",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@tiptap/extension-bubble-menu": "^3.12.1",
    "@tiptap/extension-character-count": "^3.12.1",
    "@tiptap/extension-focus": "^3.12.1",
    "@tiptap/extension-highlight": "^3.12.1",
    "@tiptap/extension-italic": "^3.12.1",
    "@tiptap/extension-paragraph": "^3.12.1",
    "@tiptap/extension-text": "^3.12.1",
    "@tiptap/extension-text-align": "^3.12.1",
    "@tiptap/extension-typography": "^3.12.1",
    "@tiptap/pm": "^3.12.1",
    "@tiptap/starter-kit": "^3.12.1",
    "@tiptap/vue-3": "^3.12.1",
    "asynciterator": "^3.10.0",
    "electron-window-state": "^5.0.3",
    "element-plus": "^2.11.9",
    "fs-extra": "^11.3.2",
    "openai": "^6.9.1",
    "tippy.js": "^6.3.7",
    "uuid": "^13.0.0",
    "vue": "^3.5.25",
    "vue-i18n": "^11.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.5",
    "electron-builder": "^26.0.12",
    "marked": "^17.0.1",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "sass": "^1.94.2",
    "sass-loader": "^16.0.6",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.2.6"
  },
  "build": {
    "productName": "Lamp",
    "appId": "lamp",
    "asar": true,
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "*.cjs",
      "config.json",
      "lang/**",
      "res/**"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "./res/app.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "linux": {}
  }
}
