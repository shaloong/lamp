{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lamp",
  "version": "1.0.0",
  "identifier": "com.shaloong.lamp",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1086",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lamp",
        "width": 1000,
        "height": 800,
        "minWidth": 375,
        "minHeight": 200,
        "decorations": false,
        "resizable": true,
        "center": true,
        "url": "http://localhost:1086"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../res/app.png",
      "../res/app.ico"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
